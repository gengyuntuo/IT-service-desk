  "query": "\n            UPDATE it_service.itsd_tickets\n            SET\n                title = $2,\n                description = $3,\n                attachments = $4,\n                category = $5,\n                status = $6,\n                priority = $7,\n                approve_user_id = $8,\n                updated_at = NOW()\n            WHERE id = $1\n            RETURNING\n                id, title, description, attachments, category,\n                status AS \"status: TicketStatus\",\n                priority AS \"priority: TicketPriority\",\n                apply_user_id, approve_user_id, created_at, updated_at, finished_at\n            ",
